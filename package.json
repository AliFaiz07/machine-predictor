{
  "name": "machine-predictor",
  "version": "1.0.0",
  "dependencies": {
    "@sap/cds": "^9"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2.4.0",
    "cds-plugin-ui5": "^0.17.0"
  },
  "scripts": {
    "start": "cds-serve",
    "watch-machines": "cds watch --open mp.machines/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-sensors": "cds watch --open mp.sensors/index.html?sap-ui-xx-viewCache=false --livereload false"
  },
  "private": true,
  "workspaces": [
    "app/*"
  ],
  "sapux": [
    "app/machines",
    "app/sensors"
  ]
}
